{
  "title": "Backend Gestor de Productos - Spring Boot",
  "uid": "backend-spring-boot",
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Peticiones HTTP / seg",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"gestor-productos\"}[5m])) by (uri, status)",
          "legendFormat": "{{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latencia p95 HTTP (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"gestor-productos\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tasa de errores 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"gestor-productos\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/seg"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uso de heap JVM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"gestor-productos\", area=\"heap\"}) by (id)",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pool de conexiones Hikari (MariaDB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"gestor-productos\"}",
          "legendFormat": "activas"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"gestor-productos\"}",
          "legendFormat": "idle"
        }
      ]
    },
    {
      "id": 6,
      "title": "Estado del Circuit Breaker (productosCB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{application=\"gestor-productos\", name=\"productosCB\"}",
          "legendFormat": "{{state}}"
        }
      ]
    }
  ]
}
